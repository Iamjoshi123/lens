# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# ─── Database ─────────────────────────────────────────────────────────────────
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://lens:lens_dev_pass@localhost:5432/lens_dev

# ─── Redis (BullMQ job queue) ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Firecrawl ────────────────────────────────────────────────────────────────
# Get your API key at https://firecrawl.dev
FIRECRAWL_API_KEY=fc-your-api-key-here
FIRECRAWL_BASE_URL=https://api.firecrawl.dev/v1
FIRECRAWL_TIMEOUT_MS=30000
FIRECRAWL_MAX_RETRIES=3
FIRECRAWL_RETRY_DELAY_MS=1000
# Daily credit budget — scraping will fail gracefully once this is exceeded
FIRECRAWL_DAILY_CREDIT_BUDGET=500

# ─── Logging ──────────────────────────────────────────────────────────────────
# Options: debug | info | warn | error
LOG_LEVEL=info

# ─── Rate Limiting ────────────────────────────────────────────────────────────
# Requests per minute
API_RATE_LIMIT_SEARCH=10
API_RATE_LIMIT_CRUD=60
